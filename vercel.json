{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/privacy-policy", "destination": "/api/legal?page=privacy-policy" },
    { "source": "/terms-of-service", "destination": "/api/legal?page=terms-of-service" },
    { "source": "/data-deletion", "destination": "/api/legal?page=data-deletion" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
